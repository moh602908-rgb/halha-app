# ============================================================
# متغيرات البيئة المطلوبة لتفعيل الذكاء الاصطناعي (المرحلة الثانية)
# ============================================================
# لا تضع القيم الحقيقية في هذا الملف — هذا الملف للتوثيق فقط ويُرفع لـ Git.
# القيم الحقيقية تُضاف من: Vercel Dashboard → Project → Settings → Environment Variables
# ============================================================

# مفتاح API الخاص بمزوّد الذكاء الاصطناعي (Anthropic). سرّي تمامًا،
# يبقى على خادم Vercel فقط ولا يصل للمتصفح إطلاقًا.
AI_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# مفتاح سرّي منفصل تمامًا عن AI_API_KEY، يُستخدم فقط لتوقيع كوكي عدّاد
# الاستخدام اليومي رقميًا (HMAC) حتى لا يستطيع أحد تعديل عدد أسئلته
# المجانية من أدوات المطوّر. أنشئ قيمة عشوائية طويلة وفريدة، مثلاً عبر:
#   node -e "console.log(crypto.randomUUID()+crypto.randomUUID())"
RATE_LIMIT_SECRET=غيّر-هذه-القيمة-إلى-نص-عشوائي-طويل-وفريد

# ============================================================
# اختياري — كلها لها قيم افتراضية معقولة داخل lib/config.js، لا حاجة
# لتعيينها إلا إذا أردت تغيير السلوك الافتراضي دون تعديل الكود.
# ============================================================

# عدد الأسئلة المجانية المسموح بها يوميًا لكل جهاز/متصفح (القرار بيد
# مالك المشروع، قابل للتغيير في أي وقت دون إعادة نشر الكود نفسه).
FREE_DAILY_LIMIT=10

# جاهز لخطة مميزة مستقبلية (غير مُفعّلة بعد — لا حسابات مستخدمين حاليًا).
PREMIUM_DAILY_LIMIT=50

# مزوّد الذكاء الاصطناعي النشط، والنماذج المستخدمة لكل خطة.
AI_PROVIDER=claude
DEFAULT_MODEL=claude-haiku-4-5-20251001
PREMIUM_MODEL=claude-sonnet-5
